# =============================================================================
# Trigger.dev v4 - Dokploy Environment Variables
# =============================================================================

# -- Passwords (generate with: openssl rand -hex 16) --------------------------
POSTGRES_PASSWORD=
REGISTRY_PASSWORD=
SESSION_SECRET=
MAGIC_LINK_SECRET=
ENCRYPTION_KEY=
MANAGED_WORKER_SECRET=
MINIO_PASSWORD=
CLICKHOUSE_PASSWORD=

# -- URLs & Domains -----------------------------------------------------------
APP_URL=https://trigger.yourdomain.com
REGISTRY_FQDN=registry.yourdomain.com
REGISTRY_URL=https://registry.yourdomain.com

# -- Database -----------------------------------------------------------------
POSTGRES_DB=trigger

# -- Docker Runner Networks ---------------------------------------------------
# IMPORTANT: Set this AFTER your first deployment.
# Run: docker network ls | grep <your-compose-project-name>
# It will be something like: <project-name>_default
DOCKER_RUNNER_NETWORKS=
